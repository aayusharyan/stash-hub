# URL of your self-hosted Stash instance (no trailing slash).
# Used server-side by the proxy routes only - never sent to the browser.
STASH_INTERNAL_URL=http://localhost:9999

# Optional: Stash API key from Settings → Security → API Key.
# Kept server-side so it is never exposed in the client bundle.
STASH_API_KEY=

# Browser-facing URL of your Stash instance. This is the only variable that reaches
# the browser. Used for the "Open Stash" footer link and all deep-links back into Stash
# (edit icons on scene, performer, and studio detail pages).
NEXT_PUBLIC_STASH_EXTERNAL_URL=http://localhost:9999

# Number of items shown per page across all listing views (default: 60).
NEXT_PUBLIC_PAGE_SIZE=60
